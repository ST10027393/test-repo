@model TechMove_GLMS.Models.RegisterModel

@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-body p-5">
                <h4 class="card-title text-primary mb-4">Register New User</h4>
                <p class="text-muted">Create a new account for the GLMS system. (Admin access required).</p>
                <hr />
                
                <form asp-action="Register">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="FirstName" class="control-label fw-bold"></label>
                            <input asp-for="FirstName" class="form-control" placeholder="Jane" />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="Surname" class="control-label fw-bold"></label>
                            <input asp-for="Surname" class="form-control" placeholder="Doe" />
                            <span asp-validation-for="Surname" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Email" class="control-label fw-bold"></label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="name@techmove.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Password" class="control-label fw-bold"></label>
                        <input asp-for="Password" class="form-control" type="password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Role" class="control-label fw-bold"></label>
                        <select asp-for="Role" class="form-select">
                            <option value="">-- Select a System Role --</option>
                            <option value="Admin">Admin</option>
                            <option value="Logistics Manager">Logistics Manager</option>
                        </select>
                        <span asp-validation-for="Role" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">Create User</button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}