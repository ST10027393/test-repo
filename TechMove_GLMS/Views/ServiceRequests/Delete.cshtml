@model TechMove_GLMS.Models.ServiceRequest
@{ ViewData["Title"] = "Delete Request"; }

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Delete Freight Job Confirmation</h4>
            </div>
            <div class="card-body p-4">
                
                <h5 class="card-title fw-bold">Request #@Model.RequestId</h5>
                <p class="text-muted mb-4">SLA Contract: #@Model.ContractId | Managed By: <strong>@Model.AssignedTo</strong></p>

                <div class="alert alert-danger">
                    <strong>Warning: Permanent Deletion</strong><br />
                    You are about to permanently delete this freight job. This will remove all financial conversion records associated with this request.
                    <br/><br/>
                    <b>Job Description:</b> @Model.Description<br/>
                    <b>Cost:</b> R @Model.LocalCostZar
                </div>

                <form asp-action="Delete" class="mt-4">
                    <input type="hidden" asp-for="RequestId" />
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger px-4">Permanently Delete</button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>