@model TechMove_GLMS.Models.Client

@{
    ViewData["Title"] = "Add New Client";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-5">
                <h4 class="card-title text-primary mb-4">Add Global Client</h4>
                <p class="text-muted">Register a new client to link with future SLAs and Service Requests.</p>
                <hr />
                
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-group mb-3">
                        <label asp-for="Name" class="control-label fw-bold">Client / Company Name</label>
                        <input asp-for="Name" class="form-control" placeholder="e.g., Acme Logistics" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="ContactDetails" class="control-label fw-bold">Primary Contact (Email)</label>
                        <input asp-for="ContactDetails" class="form-control" placeholder="contact@company.com" />
                        <span asp-validation-for="ContactDetails" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Region" class="control-label fw-bold">Global Region (Used for Currency Mapping)</label>
                        <select asp-for="Region" class="form-control select2-searchable" asp-items="ViewBag.Regions">
                            <option value="">-- Search and Select a Region --</option>
                        </select>
                        <span asp-validation-for="Region" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">Save Client</button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    
    <script>
        $(document).ready(function() {
            // Initialize the searchable dropdown with a clean UX theme
            $('.select2-searchable').select2({
                placeholder: "Search for a country...",
                allowClear: true,
                width: '100%'
            });
        });
    </script>
}