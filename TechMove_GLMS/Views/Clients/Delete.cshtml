@model TechMove_GLMS.Models.Client

@{
    ViewData["Title"] = "Delete Client";
    bool canDelete = ViewBag.CanDelete ?? false;
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Delete Client Confirmation</h4>
            </div>
            <div class="card-body p-4">
                
                <h5 class="card-title fw-bold">@Model.Name</h5>
                <p class="text-muted mb-4">@Model.ContactDetails | @Model.Region (@Model.CurrencyCode)</p>

                @if (!canDelete)
                {
                    <div class="alert alert-warning border-warning">
                        <strong>Action Blocked:</strong> This client cannot be deleted because they currently have <b>Active</b> or <b>On Hold</b> contracts in the system.<br/><br/>
                        You must expire or resolve those contracts before this client can be removed.
                    </div>
                    
                    <div class="d-grid mt-4">
                        <a asp-action="Index" class="btn btn-secondary">Return to Directory</a>
                    </div>
                }
                else
                {
                    <div class="alert alert-danger">
                        <strong>Warning: Cascade Deletion Active!</strong><br />
                        Deleting this client will permanently and irreversibly destroy:
                        <ul class="mb-0 mt-2">
                            <li>All their SLA Contracts.</li>
                            <li>All their uploaded PDF agreement files.</li>
                            <li>All related operational Service Requests.</li>
                        </ul>
                    </div>

                    <form asp-action="Delete" class="mt-4">
                        <input type="hidden" asp-for="ClientId" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger px-4">Permanently Delete</button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>