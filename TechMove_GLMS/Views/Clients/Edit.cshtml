@model TechMove_GLMS.Models.Client

@{
    ViewData["Title"] = "Edit Client";
    bool isAdmin = ViewBag.CurrentRole == "Admin";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-5">
                <h4 class="card-title text-warning mb-4">Edit Client: @Model.Name</h4>
                <p class="text-muted">Update contact details, region, or assignments.</p>
                <hr />
                
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <input type="hidden" asp-for="ClientId" />
                    <input type="hidden" asp-for="CreatedAt" />

                    <div class="form-group mb-3">
                        <label asp-for="Name" class="control-label fw-bold">Client / Company Name</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="ContactDetails" class="control-label fw-bold">Primary Contact (Email/Phone)</label>
                        <input asp-for="ContactDetails" class="form-control" />
                        <span asp-validation-for="ContactDetails" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Region" class="control-label fw-bold">Global Region</label>
                        <select asp-for="Region" class="form-control select2-searchable" asp-items="ViewBag.Regions"></select>
                        <span asp-validation-for="Region" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="AssignedTo" class="control-label fw-bold">Account Manager</label>
                        @if (isAdmin)
                        {
                            <select asp-for="AssignedTo" class="form-control select2-searchable border-warning" asp-items="ViewBag.Assignees">
                                <option value="">-- Search and Select an Account Manager --</option>
                            </select>
                            <small class="text-muted">As an admin, you can transfer ownership of this client.</small>
                        }
                        else
                        {
                            <input asp-for="AssignedTo" class="form-control bg-light" readonly />
                            <small class="text-muted">Only an administrator can reassign this client.</small>
                        }
                        <span asp-validation-for="AssignedTo" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning px-4">Update Client</button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function() {
            $('.select2-searchable').select2({ width: '100%' });
        });
    </script>
}