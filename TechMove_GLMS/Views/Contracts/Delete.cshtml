@model TechMove_GLMS.Models.Contract
@{
    ViewData["Title"] = "Delete Contract";
    bool canDelete = ViewBag.CanDelete ?? false;
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Delete SLA Confirmation</h4>
            </div>
            <div class="card-body p-4">
                <h5 class="card-title fw-bold">Contract #@Model.ContractId</h5>
                <p class="text-muted mb-4">Client: @Model.Client?.Name | Status: <strong>@Model.Status</strong></p>

                @if (!canDelete)
                {
                    <div class="alert alert-warning border-warning">
                        <strong>Action Blocked by Business Rules:</strong><br />
                        This contract cannot be deleted because it is currently <b>Active</b>, <b>On Hold</b>, or has ongoing <b>Service Requests</b> attached to it.
                    </div>
                    
                    <div class="d-grid mt-4">
                        <a asp-action="Index" class="btn btn-secondary">Return to Hub</a>
                    </div>
                }
                else
                {
                    <div class="alert alert-danger">
                        <strong>Warning:</strong> Deleting this contract is permanent and will remove the associated PDF from the server.
                    </div>

                    <form asp-action="Delete" class="mt-4">
                        <input type="hidden" asp-for="ContractId" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger px-4">Permanently Delete</button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>