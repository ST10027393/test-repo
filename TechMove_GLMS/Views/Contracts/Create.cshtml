@{
    ViewData["Title"] = "Create SLA Contract";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-5">
                <h4 class="card-title text-primary mb-4">Generate Service Level Agreement</h4>
                <hr />
                
                <form asp-action="Create" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-group mb-4">
                        <label class="control-label fw-bold">Associated Client</label>
                        <select name="ClientId" class="form-control select2-searchable" asp-items="ViewBag.Clients" required>
                            <option value="">-- Search for a Client --</option>
                        </select>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6 form-group">
                            <label class="control-label fw-bold">Start Date</label>
                            <input type="date" name="StartDate" class="form-control" required />
                        </div>
                        <div class="col-md-6 form-group">
                            <label class="control-label fw-bold">End Date</label>
                            <input type="date" name="EndDate" class="form-control" required />
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6 form-group">
                            <label class="control-label fw-bold">Service Level (Priority)</label>
                            <select name="ServiceLevel" class="form-select" required>
                                <option value="1">Level 1 (Highest Priority)</option>
                                <option value="2">Level 2</option>
                                <option value="3">Level 3 (Standard)</option>
                                <option value="4">Level 4</option>
                                <option value="5">Level 5 (Lowest Priority)</option>
                            </select>
                        </div>
                        <div class="col-md-6 form-group">
                            <label class="control-label fw-bold">Initial Status</label>
                            <select name="Status" class="form-select" required>
                                <option value="Draft">Draft (7-Day Review)</option>
                                <option value="Active">Active</option>
                                <option value="On Hold">On Hold</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group mb-4 p-3 bg-light border rounded">
                        <label class="control-label fw-bold text-danger">Upload Signed Agreement (Strict PDF Only)</label>
                        <input type="file" name="agreementFile" class="form-control mt-2" accept="application/pdf" required />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">Generate Contract</button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function() {
            $('.select2-searchable').select2({ width: '100%' });
        });
    </script>
}