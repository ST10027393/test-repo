@model TechMove_GLMS.Models.Contract

@{
    ViewData["Title"] = "Reassign Contract";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-sm border-warning">
            <div class="card-header bg-warning text-dark fw-bold">
                <i class="bi bi-arrow-left-right"></i> Reassign SLA Contract
            </div>
            <div class="card-body p-4">
                <h5 class="mb-1">@Model.Client.Name</h5>
                <p class="text-muted mb-4">Contract #@Model.ContractId | Currently assigned to: <strong>@Model.AssignedTo</strong></p>

                <form asp-action="Reassign">
                    <input type="hidden" asp-for="ContractId" />
                    
                    <div class="form-group mb-4">
                        <label class="control-label fw-bold">Transfer Ownership To:</label>
                        <select name="AssignedTo" class="form-control select2-searchable border-warning" asp-items="ViewBag.Assignees" required>
                            <option value="">-- Select New Manager --</option>
                        </select>
                        <small class="text-muted mt-2 d-block">Reassigning this contract will automatically trigger the Observer Pattern to notify the new assignee.</small>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning px-4">Execute Transfer</button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function() {
            $('.select2-searchable').select2({ width: '100%' });
        });
    </script>
}